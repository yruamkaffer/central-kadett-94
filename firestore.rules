rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /userAppState/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['data', 'schemaVersion', 'updatedAt'])
        && request.resource.data.data is map
        && request.resource.data.schemaVersion is int
        && request.resource.data.schemaVersion > 0
        && request.resource.data.updatedAt is string;
    }
  }
}
